{:deps
 {com.taoensso/timbre
  {:mvn/version "6.8.0"}

  org.clojars.akiel/iota
  {:mvn/version "0.1"}

  org.clojure/test.check
  {:mvn/version "1.1.3"}

  org.slf4j/slf4j-nop
  {:mvn/version "2.0.18"}}

 :aliases
 {:test
  {:extra-paths ["test"]}

  :kaocha
  {:extra-deps
   {lambdaisland/kaocha
    {:mvn/version "1.91.1392"}}

   :main-opts ["-m" "kaocha.runner"]}

  :coverage
  {:extra-deps
   {lambdaisland/kaocha-cloverage
    {:mvn/version "1.1.89"}}

   :main-opts ["-m" "kaocha.runner" "--profile" "coverage"]}}}
